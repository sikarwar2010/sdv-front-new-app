{
  "compilerOptions": {
    "allowJs": true,
    "strict": true,
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2021"],
    "types": ["node"]
  },
  "include": ["./**/*"],
  "exclude": ["./_generated"]
}
